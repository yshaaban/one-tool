{
  "name": "one-tool",
  "version": "0.1.0",
  "private": true,
  "description": "Stateful CLI environment for LLM agents — no sandbox required",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.11"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo": "npm run build && node --enable-source-maps dist/examples/demo-app.js",
    "agent": "npm run build && node --enable-source-maps dist/examples/agent.js",
    "test": "npm run build && node --test dist/test/*.test.js",
    "clean": "rm -rf dist agent_state"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8.3"
  }
}
