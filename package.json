{
  "name": "@onetool/one-tool",
  "version": "0.2.0",
  "license": "MIT",
  "files": [
    "dist/src/",
    "README.md",
    "LICENSE"
  ],
  "description": "Stateful CLI environment for LLM agents — no sandbox required",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.11"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./commands": {
      "types": "./dist/src/commands/index.d.ts",
      "default": "./dist/src/commands/index.js"
    },
    "./extensions": {
      "types": "./dist/src/extensions/index.d.ts",
      "default": "./dist/src/extensions/index.js"
    },
    "./mcp": {
      "types": "./dist/src/mcp/index.d.ts",
      "default": "./dist/src/mcp/index.js"
    },
    "./testing": {
      "types": "./dist/src/testing/index.d.ts",
      "default": "./dist/src/testing/index.js"
    },
    "./vfs/memory": {
      "types": "./dist/src/vfs/memory-vfs.d.ts",
      "default": "./dist/src/vfs/memory-vfs.js"
    },
    "./vfs/node": {
      "types": "./dist/src/vfs/node-vfs.d.ts",
      "default": "./dist/src/vfs/node-vfs.js"
    },
    "./browser": {
      "types": "./dist/src/browser.d.ts",
      "default": "./dist/src/browser.js"
    },
    "./vfs/browser": {
      "types": "./dist/src/vfs/browser-vfs.d.ts",
      "default": "./dist/src/vfs/browser-vfs.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "snapshots": "npm run build && node dist/scripts/snapshot.js",
    "snapshots:check": "npm run snapshots && git diff --exit-code -- snapshots/ && test -z \"$(git ls-files --others --exclude-standard -- snapshots/)\"",
    "demo": "npm run build && node --enable-source-maps dist/examples/01-hello-world.js",
    "example:hello-world": "npm run build && node --enable-source-maps dist/examples/01-hello-world.js",
    "example:custom-command": "npm run build && node --enable-source-maps dist/examples/02-custom-command.js",
    "example:readonly-agent": "npm run build && node --enable-source-maps dist/examples/03-readonly-agent.js",
    "example:detailed-execution": "npm run build && node --enable-source-maps dist/examples/04-detailed-execution.js",
    "example:adapters": "npm run build && node --enable-source-maps dist/examples/05-adapters.js",
    "example:browser-persistence": "npm run build && node --enable-source-maps dist/examples/06-browser-persistence.js",
    "example:mcp-server": "npm run build && node --enable-source-maps dist/examples/07-mcp-server.js",
    "agent": "npm run build && node --enable-source-maps dist/examples/08-llm-agent.js",
    "example:http-tool-endpoint": "npm run build && node --enable-source-maps dist/examples/advanced/http-tool-endpoint.js",
    "lint": "eslint src/ test/ examples/",
    "format": "prettier --ignore-unknown --write .env.example .prettierrc README.md COMMANDS.md CHANGELOG.md eslint.config.js docs/ src/ test/ examples/ site/",
    "format:check": "prettier --ignore-unknown --check .env.example .prettierrc README.md COMMANDS.md CHANGELOG.md eslint.config.js docs/ src/ test/ examples/ site/",
    "test": "npm run build && node --test dist/test/*.test.js dist/test/commands/*.test.js dist/test/e2e/*.test.js",
    "test:live": "npm run build && LIVE_AGENT_TESTS=1 node --test dist/test/agent-live.integration.js",
    "test:live:groq": "npm run build && LIVE_AGENT_TESTS=1 AGENT_PROVIDER=groq node --test dist/test/agent-live.integration.js",
    "test:live:openai": "npm run build && LIVE_AGENT_TESTS=1 AGENT_PROVIDER=openai node --test dist/test/agent-live.integration.js",
    "test:live:anthropic": "npm run build && LIVE_AGENT_TESTS=1 AGENT_PROVIDER=anthropic node --test dist/test/agent-live.integration.js",
    "clean": "rm -rf dist agent_state"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  }
}
