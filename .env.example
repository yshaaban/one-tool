# Copy this file to `.env` and fill in the provider you want to use.
# `.env` is ignored by git. Do not commit real API keys.
#
# Provider selection:
# - If `AGENT_PROVIDER` is unset, the agent prefers Groq when `GROQ_API_KEY`
#   is present, otherwise OpenAI when `OPENAI_API_KEY` is present.
# - Set `AGENT_PROVIDER=openai` to force OpenAI explicitly.

# AGENT_PROVIDER=openai
LIVE_AGENT_TESTS=0

# Groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_BASE_URL=https://api.openai.com/v1
