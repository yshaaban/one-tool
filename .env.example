# Copy this file to `.env` and fill in the provider you want to use.
# `.env` is ignored by git. Do not commit real API keys.
#
# Provider selection:
# - If `AGENT_PROVIDER` is unset, the agent prefers Groq when `GROQ_API_KEY`
#   is present, otherwise OpenAI when `OPENAI_API_KEY` is present, otherwise
#   Anthropic when `ANTHROPIC_API_KEY` is present.
# - Set `AGENT_PROVIDER=groq`, `AGENT_PROVIDER=openai`, or
#   `AGENT_PROVIDER=anthropic` to force one explicitly.

# AGENT_PROVIDER=groq
# AGENT_PROVIDER=openai
# AGENT_PROVIDER=anthropic
LIVE_AGENT_TESTS=0

# Groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (OpenAI-compatible endpoint)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
