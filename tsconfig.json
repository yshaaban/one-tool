{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@onetool/one-tool": ["./src/index.ts"],
      "@onetool/one-tool/commands": ["./src/commands/index.ts"],
      "@onetool/one-tool/extensions": ["./src/extensions/index.ts"],
      "@onetool/one-tool/mcp": ["./src/mcp/index.ts"],
      "@onetool/one-tool/testing": ["./src/testing/index.ts"],
      "@onetool/one-tool/browser": ["./src/browser.ts"],
      "@onetool/one-tool/vfs/memory": ["./src/vfs/memory-vfs.ts"],
      "@onetool/one-tool/vfs/node": ["./src/vfs/node-vfs.ts"],
      "@onetool/one-tool/vfs/browser": ["./src/vfs/browser-vfs.ts"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "examples/**/*.ts", "scripts/**/*.ts"]
}
